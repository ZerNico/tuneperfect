{
  "name": "tuneperfect",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --force",
    "build": "turbo run build",
    "tuneperfect": "bun run ./node_modules/@tuneperfect/cli/src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run lint . && bun run format:check ."
  },
  "dependencies": {
    "@tuneperfect/cli": "workspace:*"
  },
  "devDependencies": {
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20"
  },
  "packageManager": "bun@1.3.11"
}
